{
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ],
  "functions": {
    "api/webhook.js": {
      "bodyParser": false
    },
    "api/create-checkout.js": {
      "bodyParser": true
    },
    "api/customer-portal.js": {
      "bodyParser": true
    }
  }
}
